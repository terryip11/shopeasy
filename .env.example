# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 (圖片)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=images
# Cloudflare R2 bucket 的公開網址（R2 控制台 → bucket → 設定 → 啟用公開開發 URL）
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# AWS S3 (影片)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=videos

# Stripe（待公司戶口開通後再啟用）
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# 設為 true 且填入上方金鑰後，才開放買家信用卡付款與商家訂閱（預設關閉）
STRIPE_PAYMENTS_ENABLED=false

# App URL（Stripe 回調、Supabase OAuth / 郵件驗證 / 掃碼登入 redirect）
# 本機用手機測試時請改為電腦區域網路 IP，例如 http://192.168.0.103:3000（勿用 localhost）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 管理員掃碼登入（/login/qr；僅 admin / super_admin；設 false 可關閉）
QR_LOGIN_ENABLED=true
# 舊變數名稱仍相容
# ACCOUNTANT_QR_LOGIN_ENABLED=true

# 開發用 API（production 一律禁用，僅 development 或本機設 true）
# ALLOW_DEV_MARK_PAID=true
# ALLOW_DEV_TIER_ACTIVATE=true

# Upstash Redis 全局限流（Vercel 多實例部署強烈建議）
# 至 https://console.upstash.com 建立 Redis → REST API，複製 URL 與 Token
# 未設定時 fallback 程序內記憶體限流（僅適合本機單實例）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Web Push（PWA 推播通知）
# 執行 npm run push:generate-keys 產生金鑰
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@example.com
